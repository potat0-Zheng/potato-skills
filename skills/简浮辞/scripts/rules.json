{
  "name": "简浮辞",
  "language": "zh",
  "version": "1.0.0",
  "description": "中文文本语义压缩 - 剥离语法虚词，保留实义骨架",

  "pos_keep": {
    "_comment": "词性标签基于 jieba.posseg (PKU 词性集)",
    "always": {
      "n": "名词",
      "nr": "人名",
      "ns": "地名",
      "nt": "机构名",
      "nz": "其他专名",
      "v": "动词",
      "vd": "副动词",
      "vn": "名动词",
      "eng": "英文/外文",
      "m": "数词",
      "mq": "数量词",
      "q": "量词",
      "t": "时间词",
      "f": "方位词（空间）",
      "s": "处所词"
    },
    "contextual": {
      "a": "形容词 - 保留修饰性的，去掉冗余的",
      "d": "副词 - 保留否定/时间/程度（不、没、就、才），去掉冗余强调（很、非常、极其）",
      "p": "介词 - 保留空间/来源/目标（在、从、到），去掉语法工具（被、把、将、以）",
      "c": "连词 - 保留因果/条件（因为、所以、如果），去掉顺承（然后、并且、以及）",
      "r": "代词 - 保留疑问/指示（什么、怎么、这、那），去掉人称（我、你、他）仅在主语省略不能造成歧义时"
    }
  },

  "pos_remove": {
    "always": {
      "u": "助词（的、地、得、所、之）- 非所有格时去除",
      "y": "语气词（吧、吗、呢、啊、嘛、啦）",
      "o": "拟声词",
      "e": "叹词",
      "w": "标点中冗余逗号"
    }
  },

  "keep_exceptions": {
    "_comment": "特定词无论词性一律保留",
    "words": [
      "不", "没", "无", "非", "未", "否", "别", "莫",
      "必须", "应该", "需要", "必须", "一定",
      "所有", "每个", "任何", "全部", "部分",
      "最多", "最少", "至少", "大约", "约",
      "可能", "也许", "似乎", "好像", "大概",
      "第一", "首先", "其次", "最后", "最终",
      "例如", "比如", "包括", "尤其", "特别"
    ]
  },

  "remove_exceptions": {
    "_comment": "特定词无论词性一律去除",
    "words": [
      "的", "了", "着", "过", "地", "得",
      "很", "非常", "十分", "极其", "相当", "特别", "格外",
      "其实", "当然", "显然", "的确", "确实",
      "因此", "所以", "于是", "然后", "接着",
      "总之", "总而言之", "综上所述",
      "的话", "来说", "来讲", "而言",
      "进行", "给予", "加以", "予以", "作",
      "一个", "一种", "某个", "某些", "该", "本", "此"
    ]
  },

  "compression_presets": {
    "light": {
      "desc": "轻度压缩 - 仅去冗余副词和语气词，保留完整可读性",
      "remove_intensifiers": true,
      "remove_particles": false,
      "remove_conjunctions": false,
      "remove_pronouns": false,
      "target_ratio": 0.85
    },
    "medium": {
      "desc": "中度压缩 - 去虚词和部分连词，保持基本可读",
      "remove_intensifiers": true,
      "remove_particles": true,
      "remove_conjunctions": true,
      "remove_pronouns": false,
      "target_ratio": 0.65
    },
    "heavy": {
      "desc": "重度压缩 - 最大密度的语义提取",
      "remove_intensifiers": true,
      "remove_particles": true,
      "remove_conjunctions": true,
      "remove_pronouns": true,
      "target_ratio": 0.45
    }
  }
}
